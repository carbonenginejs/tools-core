{
    "name": "@carbonenginejs/tools-core",
    "version": "0.2.0",
    "description": "Node toolchain for CarbonEngineJS acquisition, generated libraries, caches, graph output, and optional HTTP and realtime service hosting.",
    "type": "module",
    "main": "src/index.js",
    "exports": {
        ".": "./src/index.js",
        "./audio": "./src/audio/index.js",
        "./black": "./src/black/index.js",
        "./cache": "./src/cache/index.js",
        "./character": "./src/character/index.js",
        "./index": "./src/indexing/index.js",
        "./integrations/kick": "./src/integrations/kick/index.js",
        "./integrations/twitch": "./src/integrations/twitch/index.js",
        "./library": "./src/library/index.js",
        "./proxy": "./src/proxy/index.js",
        "./realtime": "./src/realtime/index.js",
        "./realtime/livestream": "./src/realtime/livestream/index.js",
        "./realtime/resource-watch": "./src/realtime/resource-watch/index.js",
        "./realtime/server": "./src/realtime/server/index.js",
        "./realtime/websocket": "./src/realtime/websocket/index.js",
        "./schema": "./src/schema/index.js",
        "./service": "./src/service/index.js",
        "./sde": "./src/sde/index.js",
        "./shader": "./src/shader/index.js",
        "./skin": "./src/skin/index.js",
        "./target": "./src/target/index.js",
        "./webhook": "./src/webhook/index.js",
        "./weapon": "./src/weapon/index.js",
        "./utils": "./src/utils.js"
    },
    "bin": {
        "cjs-index": "bin/cjs-tool-index.js",
        "cjs-tool-index": "bin/cjs-tool-index.js",
        "cjs-tools-index": "bin/cjs-tool-index.js",
        "cjs-tools-service": "bin/cjs-tools-service.js",
        "cjs-sde-prepare": "bin/cjs-sde-prepare.js",
        "cjs-character-library": "bin/cjs-character-json.js",
        "character-library-json": "bin/cjs-character-json.js",
        "cjs-character-json": "bin/cjs-character-json.js",
        "carbon-class": "bin/cjs-carbon-class.js",
        "cjs-carbon-class": "bin/cjs-carbon-class.js",
        "carbon-schema": "bin/cjs-carbon-schema.js",
        "cjs-carbon-schema": "bin/cjs-carbon-schema.js"
    },
    "files": [
        "bin/",
        "docs/",
        "providers/",
        "scripts/",
        "!scripts/carbon-blue/reports/",
        "src/",
        "README.md",
        "LICENSE",
        "NOTICE"
    ],
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "start": "node bin/cjs-tool-index.js",
        "service": "node bin/cjs-tools-service.js",
        "prepare:sde": "node bin/cjs-sde-prepare.js",
        "build:audio": "node scripts/build_audio_library.js",
        "build:character": "node scripts/build_character_library.js",
        "build:skins": "node scripts/build_skin_libraries.js",
        "build:weapons": "node scripts/build_weapon_library.js",
        "catalog:shader": "node scripts/catalog_shader_targets.js",
        "build:shader:webgl": "node scripts/build_webgl_shaders.js",
        "build:shader:webgpu": "node scripts/build_webgpu_shaders.js",
        "export:character": "node bin/cjs-character-json.js",
        "scan": "node scripts/carbon-blue/convert.cjs",
        "scan:trinity": "node scripts/carbon-blue/convert.cjs --config scripts/carbon-blue/config/trinity-root.json",
        "schema:build": "node scripts/build_carbon_schema.js scripts/carbon-blue/reports/latest.json scripts/carbon-blue/reports/trinity-root-latest.json --clean",
        "schema:generate": "npm run scan && npm run scan:trinity && npm run schema:build",
        "lint": "node lint_package.js",
        "test": "node --test",
        "check": "npm run lint && npm test"
    },
    "dependencies": {
        "@carbonenginejs/core-types": "^0.12.0",
        "@carbonenginejs/format-webgl": "^0.1.6",
        "@carbonenginejs/format-webgpu": "^0.2.1",
        "@carbonenginejs/runtime-audio": "^0.1.0",
        "@carbonenginejs/runtime-resource": "^0.8.0",
        "@carbonenginejs/runtime-sof": "^0.2.0",
        "@carbonenginejs/runtime-trinity": "^0.4.0",
        "better-sqlite3": "^11.10.0",
        "unzipper": "^0.12.5",
        "ws": "^8.21.1"
    },
    "sideEffects": false,
    "keywords": [
        "carbonenginejs",
        "tools-core",
        "eve-online",
        "appfileindex",
        "resfileindex",
        "sde",
        "skin",
        "skinr",
        "weapons",
        "character",
        "realtime",
        "filesystem-watch",
        "kick",
        "twitch",
        "webhook",
        "websocket",
        "sof",
        "shader",
        "webgl",
        "webgpu"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/carbonenginejs/tools-core.git"
    },
    "homepage": "https://github.com/carbonenginejs/tools-core#readme",
    "bugs": {
        "url": "https://github.com/carbonenginejs/tools-core/issues"
    },
    "publishConfig": {
        "access": "public"
    }
}
